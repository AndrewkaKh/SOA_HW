PYTHONUNBUFFERED=1

KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9093
KAFKA_TOPIC=movie-events
SCHEMA_REGISTRY_URL=http://schema-registry:8081

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=default

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics

MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=movie-analytics
MINIO_REGION=us-east-1

GENERATOR_ENABLED=true
GENERATOR_INTERVAL_SECONDS=2
GENERATOR_BACKFILL_DAYS=9

AGGREGATION_INTERVAL_SECONDS=30
AGGREGATION_BOOTSTRAP_DAYS=8
TOP_MOVIES_LIMIT=20

EXPORT_INTERVAL_SECONDS=60

PRODUCER_PORT=8000
AGGREGATOR_PORT=8001
EXPORTER_PORT=8002
